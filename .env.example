# Copy to .env (gitignored) and fill in. voice-evals reads these from the environment.

# --- LLM judge / user-simulator / caller-bot (OpenAI) ---
OPENAI_API_KEY=sk-...

# --- Telephony caller (voice-evals call) — real Twilio call + barge-in ---
# Twilio API credentials (Account SID + Auth Token from the Twilio console)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Your Twilio number to originate the call from (caller ID)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# The agent's number to dial (your dev agent behind its own Twilio number + ngrok)
TWILIO_AGENT_NUMBER=+1YYYYYYYYYY
# wss URL Twilio streams the call audio to — your tunnel to `voice-evals call`'s
# media server (default port 8080). e.g. ngrok http 8080  ->  wss://<id>.ngrok.app/caller
PUBLIC_STREAM_URL=wss://<your-tunnel>/caller

# --- Optional: hosted Gemini judge / pyannote diarization ---
# GEMINI_API_KEY=...
# HF_TOKEN=...
